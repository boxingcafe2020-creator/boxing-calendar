# Supabase（Supabaseのプロジェクト設定から取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxx

# サイトURL（Vercelデプロイ後に設定）
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Cron認証シークレット（自分でランダムな文字列を設定）
CRON_SECRET=your-random-secret-here

# 楽天アカウント（boxmob.jpスクレイピング用）
RAKUTEN_ID=your-rakuten-id
RAKUTEN_PASSWORD=your-rakuten-password

# Gmail通知（オプション）
GMAIL_USER=boxingcafe2020@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
